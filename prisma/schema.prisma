generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  passwordHash  String
  role          String      @default("ENGINEER") // ADMIN, MANAGER, ENGINEER
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  jobs          Job[]
  accessLogs    AccessLog[]
  settings      UserSettings?
}

model UserSettings {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  defaultStockLengthMm   Float    @default(12000)
  defaultMinOffcutMm     Float    @default(500)
  allowMixedStockLengths Boolean  @default(false)
  scrapThresholdWarning  Float    @default(5)
  updatedAt              DateTime @updatedAt

  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccessLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Job {
  id              String   @id @default(uuid())
  name            String
  projectName     String?
  stockLengthMm   Float    @default(12000)
  minOffcutToSaveMm Float  @default(500)
  allowOffcutReuse Boolean @default(true)
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  requirements    RebarRequirement[]
  stockBars       StockBar[]
  offcutsGenerated Offcut[] @relation("JobGeneratedOffcuts")
}

model RebarRequirement {
  id               String   @id @default(uuid())
  jobId            String
  diameterMm       Float
  requiredLengthMm Float
  quantity         Int
  location         String?
  createdAt        DateTime @default(now())

  job              Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cutPieces        CutPiece[]
}

model StockBar {
  id                  String   @id @default(uuid())
  jobId               String
  diameterMm          Float
  totalLengthMm       Float
  remainingLengthMm   Float
  isScrap             Boolean  @default(false)
  createdAt           DateTime @default(now())

  job                 Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cutPieces           CutPiece[]
}

model CutPiece {
  id                  String   @id @default(uuid())
  stockBarId          String
  requirementId       String
  lengthMm            Float
  createdAt           DateTime @default(now())

  stockBar            StockBar         @relation(fields: [stockBarId], references: [id], onDelete: Cascade)
  requirement         RebarRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model Offcut {
  id                  String   @id @default(uuid())
  diameterMm          Float
  lengthMm            Float
  sourceJobId         String?
  status              String   @default("AVAILABLE") // AVAILABLE, REUSED
  createdAt           DateTime @default(now())

  sourceJob           Job?     @relation("JobGeneratedOffcuts", fields: [sourceJobId], references: [id])
}
